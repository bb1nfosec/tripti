# Tripti environment variables
#
# Tripti is local-first and BYOLLM: end users paste their OWN provider key into
# the app, and it is stored only in their browser (IndexedDB). The app needs NO
# env vars to run.
#
# The variables below are OPTIONAL and only for an operator who wants to offer
# "Shared test access" — a free, zero-setup way for trusted testers to try the
# app using a key YOU provide. The key is read ONLY on the server and is never
# sent to the browser. Leave these unset and the Shared-access option stays
# hidden by default.

# A free-tier provider key the server uses for "Shared test access".
# Get a free Groq key at https://console.groq.com/keys
# TRIPTI_OPERATOR_KEY=

# Which provider the operator key is for: "groq" (default) or "openai".
# TRIPTI_OPERATOR_TARGET=groq

# The model the operator path uses.
# TRIPTI_OPERATOR_MODEL=llama-3.3-70b-versatile
